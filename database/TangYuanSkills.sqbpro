	&quot;ID&quot; INTEGER PRIMARY KEY AUTOINCREMENT,  -- 主键
	&quot;SkillCode&quot; TEXT NOT NULL,                -- 指令关键词/匹配码（如：打开淘宝、查天气、打开文档）
	&quot;SkillActions&quot; TEXT NOT NULL,              -- 动作指令集（JSON格式，给插件用）
	&quot;SkillType&quot; TEXT NOT NULL,                -- 类型：Browser/System/Official 等
	&quot;NeedLogin&quot; INTEGER DEFAULT 0,            -- 是否需要登录 0=否 1=是
	&quot;UpdateTime&quot; TEXT NOT NULL,               -- 更新时间
	&quot;WebSiteName&quot; TEXT,                       -- 网站名称（浏览器专用）
	&quot;WebSiteUrl&quot; TEXT,                        -- 网站URL（浏览器专用）
	&quot;Other&quot; TEXT,                             -- 扩展备用字段
	&quot;Remark&quot; TEXT                             -- 备注（方便你管理）
);</sql><current_tab id="0"/></tab_sql></sqlb_project>
