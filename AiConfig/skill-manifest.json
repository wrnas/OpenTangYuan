        "SkillCode": "screenshot_task",
        "Arguments": {}
      }
    },
    {
      "skillCode": "open_task",
      "desc": "打开文件、程序、文件夹",
      "args": {
        "path": "文件路径、目录路径或程序路径"
      },
      "example": {
        "SkillCode": "open_task",
