    {
      "skillCode": "wechat_task",
      "desc": "发送企业微信机器人消息，支持文本、Markdown、图文卡片",
      "args": {
        "action": "text / markdown / card",
        "content": "text 或 markdown 时必填",
        "isAtAll": "text 时可选，true/false",
        "atUsers": "text 时可选，多个用户用逗号分隔",
