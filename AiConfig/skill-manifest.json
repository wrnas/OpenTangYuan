{
  "builtins": [
    {
      "skillCode": "browser_task",
      "AIDesc": "网页操作。支持打开网页、点击、输入、提取文本、截图、下载、分页和复用 session。",
      "usage": [
        "用于网页浏览、网页截图、网页内容提取。",
        "优先复用 sessionId，不要重复登录。",
        "常见参数是 actions，actions 是浏览器动作数组。"
      ],
      "examples": [
        {
          "title": "打开网页并截图",
          "json": {
            "SkillCode": "browser_task",
            "Arguments": {
              "actions": [
                {
                  "type": "goto",
                  "url": "https://example.com"
                },
                {
                  "type": "wait_for",
                  "selector": "body"
                },
                { "type": "screenshot" }
              ]
            }
          }
        }
      ],
      "tips": [
        "网页截图优先使用 browser_task。",
        "不要把本地界面截图交给 browser_task。"
      ]
    },
    {
      "skillCode": "file_task",
      "AIDesc": "文件操作。支持 search、copy、move、mkdir、rename、copy_many、move_many。",
      "usage": [
        "用于文件搜索、复制、移动、重命名、创建目录。",
        "有副作用动作成功后不要重复执行。"
      ],
      "examples": [
        {
          "title": "搜索文件",
          "json": {
            "SkillCode": "file_task",
            "Arguments": {
              "action": "search",
              "keyword": "发票",
              "ext": "pdf"
            }
          }
        }
      ],
      "tips": [
        "search 返回列表时，列表本身通常就是结果。",
        "copy、move、rename、mkdir 成功后立即停止。"
      ]
    },
    {
      "skillCode": "wechat_task",
      "AIDesc": "企业微信机器人消息发送。仅支持 text、markdown、card。",
      "usage": [
        "用于发送企业微信机器人消息。",
        "action 只能是 text、markdown、card。"
      ],
      "examples": [
        {
          "title": "发送文本消息",
          "json": {
            "SkillCode": "wechat_task",
            "Arguments": {
              "action": "text",
              "content": "测试一下，你好！"
            }
          }
        }
      ],
      "tips": [
        "成功后必须立即停止。",
        "不要使用 send、message、notify 之类未定义 action。"
      ]
    },
    {
      "skillCode": "email_task",
      "AIDesc": "邮箱操作。支持 send、search、read、download_attachments、reply、mark_read、save_eml。",
      "usage": [
        "send: 发送邮件，常用参数 to、subject、body、attachments、insertImagePaths。",
        "search: 搜索邮件列表，常用参数 subjectKeyword、fromKeyword、bodyKeyword、unreadOnly、hasAttachments、maxCount、scanCount、contextKey。",
        "read: 读取邮件正文，常用参数 index + contextKey，或 mailRef。",
        "download_attachments: 下载附件，常用参数 index + contextKey，或 mailRef + savePath。",
        "reply: 回复邮件，常用参数 index + contextKey，或 mailRef + replyText。",
        "mark_read: 标记已读，常用参数 index + contextKey，或 mailRef。",
        "save_eml: 保存邮件为 eml，常用参数 index + contextKey，或 mailRef + filePath。"
      ],
      "examples": [
        {
          "title": "搜索主题包含 发票 的邮件",
          "json": {
            "SkillCode": "email_task",
            "Arguments": {
              "action": "search",
              "subjectKeyword": "发票",
              "maxCount": 10,
              "scanCount": 100,
              "contextKey": "mail_default"
            }
          }
        },
        {
          "title": "读取第一封邮件",
          "json": {
            "SkillCode": "email_task",
            "Arguments": {
              "action": "read",
              "index": 1,
              "contextKey": "mail_default"
            }
          }
        },
        {
          "title": "下载第一封邮件附件",
          "json": {
            "SkillCode": "email_task",
            "Arguments": {
              "action": "download_attachments",
              "index": 1,
              "contextKey": "mail_default",
              "savePath": "D:\\MailDownloads"
            }
          }
        },
        {
          "title": "发送带正文图片的邮件",
          "json": {
            "SkillCode": "email_task",
            "Arguments": {
              "action": "send",
              "to": "someone@example.com",
              "subject": "测试邮件",
              "body": "你好，下面这张图请查看：",
              "insertImagePaths": [
                "C:\\a.png"
              ]
            }
          }
        }
      ],
      "tips": [
        "查邮件列表时先 search，列表成功后默认立即停止，不要自动查看详情。",
        "用户说第一封邮件、第二封邮件时，优先用 index + contextKey。",
        "图片作为附件发送用 attachments；图片显示在正文中用 insertImagePaths。",
        "send、reply、mark_read、download_attachments、save_eml 都是有副作用动作，成功后立即停止。"
      ]
    }
  ]
}
