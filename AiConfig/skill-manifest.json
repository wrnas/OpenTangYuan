{
  "version": "1.1",
  "note": "优先使用 workflows；没有现成 workflow 或 workflow 只能完成一部分时，再使用 builtins 组合调用 ExecuteSkill。",
  "skills": [
    {
      "skillCode": "browser_task",
      "desc": "执行浏览器自动化动作序列，适用于登录、查询、读取页面、截图、下载、多轮页面操作等场景",
      "args": {
        "sessionId": "可选，会话ID，不传则自动新建；同一网站后续追问应优先复用",
        "closeSession": "可选，是否执行后关闭会话 true/false，默认 false",
        "includeOutputs": "可选，是否返回每一步动作明细 true/false，默认 false",
        "actions": "浏览器动作数组；可直接传 JSON 数组，或以 JSON 字符串形式传入"
      },
      "actionsV1": [
        "goto",
        "goto_attr",
        "back",
        "forward",
        "refresh",
        "click",
        "click_index",
        "click_text",
        "click_if_exists",
        "fill",
        "press",
        "hover",
        "select_option",
        "wait",
        "wait_for",
        "wait_for_load_state",
        "wait_url_contains",
        "scroll_bottom",
        "scroll_until_text",
        "get_text",
        "get_text_list",
        "get_attr",
        "get_attr_list",
        "get_links",
        "get_links_structured",
        "get_html",
        "check_text",
        "exists",
        "count",
        "analyze_page",
        "extract_article",
        "extract_list",
        "screenshot",
        "screenshot_base64",
        "screenshot_element",
        "download",
        "new_tab",
        "switch_tab",
        "get_tabs",
        "clear_cookies",
        "auto_detect_login",
        "auto_login_form",
        "evaluate",
        "detect_captcha",
        "capture_captcha",
        "submit_captcha"
      ],
      "example": {
        "SkillCode": "browser_task",
        "Arguments": {
          "closeSession": false,
          "includeOutputs": false,
          "actions": [
            {
              "type": "goto",
              "url": "https://example.com"
            },
            {
              "type": "wait_for",
              "selector": "body"
            },
            {
              "type": "get_text",
              "selector": "body"
            }
          ]
        }
      }
    },

    {
      "skillCode": "file_task",
      "desc": "文件搜索、复制、移动、重命名、创建目录、批量复制、批量移动",
      "args": {
        "action": "search | copy | move | copy_many | move_many | mkdir | rename",
        "from": "源路径；copy/move/rename/mkdir 时使用",
        "to": "目标路径；copy/move 时使用",
        "keyword": "搜索关键词；search 时使用",
        "ext": "扩展名；search 时使用，默认 *",
        "paths": "文件路径数组；copy_many/move_many 时使用",
        "toDir": "目标目录；copy_many/move_many 时使用",
        "overwrite": "是否覆盖，true/false，默认 true",
        "newName": "重命名后的文件名；rename 时使用"
      },
      "actions": [
        {
          "action": "search",
          "required": [ "keyword" ],
          "optional": [ "ext" ]
        },
        {
          "action": "copy",
          "required": [ "from", "to" ],
          "optional": []
        },
        {
          "action": "move",
          "required": [ "from", "to" ],
          "optional": []
        },
        {
          "action": "copy_many",
          "required": [ "paths", "toDir" ],
          "optional": [ "overwrite" ]
        },
        {
          "action": "move_many",
          "required": [ "paths", "toDir" ],
          "optional": [ "overwrite" ]
        },
        {
          "action": "rename",
          "required": [ "from", "newName" ],
          "optional": []
        },
        {
          "action": "mkdir",
          "required": [ "from" ],
          "optional": []
        }
      ],
      "example": {
        "SkillCode": "file_task",
        "Arguments": {
          "action": "copy_many",
          "paths": [
            "C:\\Temp\\a.png",
            "C:\\Temp\\b.png"
          ],
          "toDir": "D:\\备份",
          "overwrite": "true"
        }
      }
    },

    {
      "skillCode": "email_task",
      "AIDesc": "邮箱相关操作。支持发邮件、搜索邮件、读取邮件正文、下载附件、回复邮件、标记已读、保存eml。调用时请传 action 和对应参数。",
      "args": [
        {
          "name": "action",
          "type": "string",
          "required": true,
          "desc": "操作类型。可选：send, search, read, download_attachments, reply, mark_read, save_eml"
        },
        {
          "name": "to",
          "type": "string",
          "required": false,
          "desc": "收件人邮箱，多个可用逗号或分号分隔。action=send 时需要"
        },
        {
          "name": "subject",
          "type": "string",
          "required": false,
          "desc": "邮件主题。action=send 时可传"
        },
        {
          "name": "body",
          "type": "string",
          "required": false,
          "desc": "邮件正文。action=send 时可传"
        },
        {
          "name": "attachments",
          "type": "array",
          "required": false,
          "desc": "附件路径数组。action=send 或 reply 时可传"
        },
        {
          "name": "insertImagePaths",
          "type": "array",
          "required": false,
          "desc": "插入到邮件正文里的图片路径数组。action=send 时可传"
        },
        {
          "name": "subjectKeyword",
          "type": "string",
          "required": false,
          "desc": "搜索邮件时按主题关键词过滤。action=search 时可传"
        },
        {
          "name": "fromKeyword",
          "type": "string",
          "required": false,
          "desc": "搜索邮件时按发件人关键词过滤。action=search 时可传"
        },
        {
          "name": "bodyKeyword",
          "type": "string",
          "required": false,
          "desc": "搜索邮件时按正文关键词过滤。action=search 时可传"
        },
        {
          "name": "unreadOnly",
          "type": "bool",
          "required": false,
          "desc": "是否只搜索未读邮件。action=search 时可传"
        },
        {
          "name": "hasAttachments",
          "type": "bool",
          "required": false,
          "desc": "是否只搜索带附件的邮件。action=search 时可传"
        },
        {
          "name": "maxCount",
          "type": "int",
          "required": false,
          "desc": "搜索最多返回多少封。action=search 时可传，建议 10"
        },
        {
          "name": "contextKey",
          "type": "string",
          "required": false,
          "desc": "搜索结果上下文标识。search/read/download_attachments/reply/mark_read/save_eml 可传，默认 default"
        },
        {
          "name": "index",
          "type": "int",
          "required": false,
          "desc": "邮件序号。通常在先 search 后，再 read/download_attachments/reply/mark_read/save_eml 时传，例如第 1 封"
        },
        {
          "name": "mailRef",
          "type": "string",
          "required": false,
          "desc": "邮件引用标识，例如 INBOX:12345。可代替 index 使用"
        },
        {
          "name": "savePath",
          "type": "string",
          "required": false,
          "desc": "附件保存目录。action=download_attachments 时需要"
        },
        {
          "name": "replyText",
          "type": "string",
          "required": false,
          "desc": "回复正文。action=reply 时需要"
        },
        {
          "name": "replyHtml",
          "type": "string",
          "required": false,
          "desc": "回复 HTML 正文。action=reply 时可传"
        },
        {
          "name": "replyToAll",
          "type": "bool",
          "required": false,
          "desc": "是否回复所有人。action=reply 时可传"
        },
        {
          "name": "filePath",
          "type": "string",
          "required": false,
          "desc": "保存 eml 的文件路径。action=save_eml 时需要"
        }
      ],
      "examples": [
        {
          "title": "搜索主题包含 2026 的未读邮件",
          "json": {
            "skillCode": "email_task",
            "arguments": {
              "action": "search",
              "subjectKeyword": "2026",
              "unreadOnly": true,
              "maxCount": 10,
              "contextKey": "mail_default"
            }
          }
        },
        {
          "title": "读取刚才搜索结果中的第一封邮件",
          "json": {
            "skillCode": "email_task",
            "arguments": {
              "action": "read",
              "index": 1,
              "contextKey": "mail_default"
            }
          }
        },
        {
          "title": "下载第一封邮件附件到 D 盘",
          "json": {
            "skillCode": "email_task",
            "arguments": {
              "action": "download_attachments",
              "index": 1,
              "contextKey": "mail_default",
              "savePath": "D:\\MailDownloads"
            }
          }
        },
        {
          "title": "发送带正文图片的邮件",
          "json": {
            "skillCode": "email_task",
            "arguments": {
              "action": "send",
              "to": "someone@example.com",
              "subject": "测试邮件",
              "body": "你好，下面这张图请查看：",
              "insertImagePaths": [
                "C:\\a.png"
              ]
            }
          }
        }
      ],
      "tips": [
        "先用 search 获取邮件列表，再用 index 或 mailRef 做后续操作。",
        "当用户说“第一封邮件”时，优先传 index=1 和 contextKey。",
        "发送正文带图片的邮件时，优先使用 insertImagePaths，不要自己拼 cid。",
        "调用 ExecuteSkillForCoze 时，可把整个对象转成 Json 字符串后传入 Json 字段。"
      ]
    }
,

