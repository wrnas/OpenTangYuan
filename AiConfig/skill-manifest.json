{
  "version": "1.1",
  "note": "优先使用 workflows；没有现成 workflow 或 workflow 只能完成一部分时，再使用 builtins 组合调用 ExecuteSkill。",
  "skills": [
    {
      "skillCode": "browser_task",
      "desc": "执行浏览器自动化动作序列，适用于登录、查询、读取页面、截图、下载、多轮页面操作等场景",
      "args": {
        "sessionId": "可选，会话ID，不传则自动新建；同一网站后续追问应优先复用",
        "closeSession": "可选，是否执行后关闭会话 true/false，默认 false",
        "includeOutputs": "可选，是否返回每一步动作明细 true/false，默认 false",
        "actions": "浏览器动作数组；可直接传 JSON 数组，或以 JSON 字符串形式传入"
      },
      "actionsV1": [
        "goto",
        "goto_attr",
        "back",
        "forward",
        "refresh",
        "click",
        "click_index",
        "click_text",
        "click_if_exists",
        "fill",
        "press",
        "hover",
        "select_option",
        "wait",
        "wait_for",
        "wait_for_load_state",
        "wait_url_contains",
        "scroll_bottom",
        "scroll_until_text",
        "get_text",
        "get_text_list",
        "get_attr",
        "get_attr_list",
        "get_links",
        "get_links_structured",
        "get_html",
        "check_text",
        "exists",
        "count",
        "analyze_page",
        "extract_article",
        "extract_list",
        "screenshot",
        "screenshot_base64",
        "screenshot_element",
        "download",
        "new_tab",
        "switch_tab",
        "get_tabs",
        "clear_cookies",
        "auto_detect_login",
        "auto_login_form",
        "evaluate",
        "detect_captcha",
        "capture_captcha",
        "submit_captcha"
      ],
      "example": {
        "SkillCode": "browser_task",
        "Arguments": {
          "closeSession": false,
          "includeOutputs": false,
          "actions": [
            {
              "type": "goto",
              "url": "https://example.com"
            },
            {
              "type": "wait_for",
              "selector": "body"
            },
            {
              "type": "get_text",
              "selector": "body"
            }
          ]
        }
      }
    },

    {
      "skillCode": "file_task",
      "desc": "文件搜索、复制、移动、重命名、创建目录、批量复制、批量移动",
      "args": {
        "action": "search | copy | move | copy_many | move_many | mkdir | rename",
        "from": "源路径；copy/move/rename/mkdir 时使用",
        "to": "目标路径；copy/move 时使用",
        "keyword": "搜索关键词；search 时使用",
        "ext": "扩展名；search 时使用，默认 *",
        "paths": "文件路径数组；copy_many/move_many 时使用",
        "toDir": "目标目录；copy_many/move_many 时使用",
        "overwrite": "是否覆盖，true/false，默认 true",
        "newName": "重命名后的文件名；rename 时使用"
      },
      "actions": [
        {
          "action": "search",
          "required": [ "keyword" ],
          "optional": [ "ext" ]
        },
        {
          "action": "copy",
          "required": [ "from", "to" ],
          "optional": []
        },
        {
          "action": "move",
          "required": [ "from", "to" ],
          "optional": []
        },
        {
          "action": "copy_many",
          "required": [ "paths", "toDir" ],
          "optional": [ "overwrite" ]
        },
        {
          "action": "move_many",
          "required": [ "paths", "toDir" ],
          "optional": [ "overwrite" ]
        },
        {
          "action": "rename",
          "required": [ "from", "newName" ],
          "optional": []
        },
        {
          "action": "mkdir",
          "required": [ "from" ],
          "optional": []
        }
      ],
      "example": {
        "SkillCode": "file_task",
        "Arguments": {
          "action": "copy_many",
          "paths": [
            "C:\\Temp\\a.png",
            "C:\\Temp\\b.png"
          ],
          "toDir": "D:\\备份",
          "overwrite": "true"
        }
      }
    },

    {
      "skillCode": "email_task",
      "desc": "发送邮件，支持多个收件人和多个附件",
      "args": {
        "to": "收件人邮箱，必填；支持多个，使用逗号或分号分隔",
        "subject": "邮件主题，可空",
        "body": "邮件正文，可空；content 也可兼容",
        "attachment": "单个附件完整路径，可空",
        "attachments": "多个附件完整路径数组，可空"
      },
      "example": {
        "SkillCode": "email_task",
        "Arguments": {
          "to": "214634166@qq.com,example1@qq.com",
          "subject": "测试邮件",
          "body": "这是测试正文",
          "attachments": [
            "D:\\a.png",
            "D:\\b.xlsx"
          ]
        }
      }
    },
