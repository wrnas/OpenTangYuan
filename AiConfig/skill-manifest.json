{
  "version": "1.0",
  "note": "优先使用 workflows；没有现成技能时，再使用 builtins 组合调用 ExecuteSkill。",
  "skills": [
    {
      "skillCode": "browser_task",
      "desc": "执行浏览器自动化动作序列，适用于登录、查询、读取页面、截图、下载等场景",
      "args": {
        "sessionId": "可选，会话ID，不传则自动新建",
        "closeSession": "可选，是否执行后关闭会话 true/false",
        "actions": "浏览器动作数组"
      },
      "actionsV1": [
        "goto",
        "back",
        "forward",
        "refresh",
        "click",
        "fill",
        "press",
        "select_option",
        "wait",
        "wait_for",
        "wait_for_load_state",
        "wait_url_contains",
        "get_text",
        "get_text_list",
        "get_attr",
        "exists",
        "count",
        "screenshot",
        "screenshot_element",
        "download",
        "new_tab",
        "switch_tab",
        "get_tabs"
      ],
      "example": {
        "SkillCode": "browser_task",
        "Arguments": {
          "closeSession": true,
          "actions": [
            {
              "type": "goto",
              "url": "https://example.com"
            },
            {
              "type": "wait_for",
              "selector": "body"
            },
            {
              "type": "get_text",
              "selector": "title"
            }
          ]
        }
      }
    } ,
    {
      "skillCode": "file_task",
      "desc": "文件搜索、复制、移动、创建目录",
      "args": {
        "action": "search | copy | move | mkdir",
        "from": "源路径；copy/move/mkdir 时使用",
        "to": "目标路径；copy/move 时使用",
        "keyword": "搜索关键词；search 时使用",
        "ext": "扩展名；search 时使用，默认 *"
      },
      "actions": [
        {
          "action": "search",
          "required": [ "keyword" ],
          "optional": [ "ext" ]
        },
        {
          "action": "copy",
          "required": [ "from", "to" ],
          "optional": []
        },
        {
          "action": "move",
          "required": [ "from", "to" ],
          "optional": []
        },
        {
          "action": "mkdir",
          "required": [ "from" ],
          "optional": []
        }
      ],
      "example": {
        "SkillCode": "file_task",
        "Arguments": {
          "action": "copy",
          "from": "C:\\Temp\\a.png",
          "to": "D:\\a.png"
        }
      }
    },
    {
      "skillCode": "email_task",
      "desc": "发送邮件，可带单个附件",
      "args": {
        "to": "收件人邮箱，必填",
        "subject": "邮件主题，可空",
        "body": "邮件正文，可空",
        "attachment": "附件完整路径，可空"
      },
      "example": {
        "SkillCode": "email_task",
        "Arguments": {
          "to": "214634166@qq.com",
          "subject": "测试邮件",
          "body": "这是测试正文",
          "attachment": "D:\\a.png"
        }
      }
    },
